# ─────────────────────────────────────────────
# DaronsFC — variables d'environnement
# Copier ce fichier en `.env.local` et remplir.
# ─────────────────────────────────────────────

# Auth (NextAuth.js v5)
# Générer un secret : `npx auth secret` ou `openssl rand -base64 32`
AUTH_SECRET=
# URL publique de l'app (NextAuth v5 utilise AUTH_URL, pas NEXTAUTH_URL)
AUTH_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# Google OAuth
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Database (Postgres local via Docker, ou Supabase Postgres poolé)
# Exemple Docker local :
#   postgresql://daronsfc:daronsfc@localhost:5432/daronsfc?schema=public
DATABASE_URL=
DIRECT_URL=

# football-data.org (GRATUIT) — source des matchs.
# Token gratuit (email) : https://www.football-data.org/client/register
FOOTBALL_DATA_TOKEN=
# Code compétition à synchroniser (défaut : WC = Coupe du Monde).
FOOTBALL_DATA_COMPETITION=WC

# Web Push (Sprint 4) — générer : `npx web-push generate-vapid-keys`
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
